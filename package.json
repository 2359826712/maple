{
  "name": "mpstorys",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "npm run build:data",
    "build": "next build --webpack",
    "start": "next start",
    "dev:vite": "vite",
    "build:vite": "vite build",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.app.json",
    "typecheck": "npm run type-check",
    "pretest": "npm run build:data",
    "test": "vitest run --maxWorkers=4",
    "validate": "node scripts/validate-data.mjs",
    "validate:resources": "node scripts/validate-resources.mjs",
    "validate:sources": "node scripts/validate-sources.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "check:duplicates": "node scripts/check-duplicates.mjs",
    "check:links": "node scripts/check-links.mjs",
    "build:data": "node scripts/build-index.mjs",
    "build:search": "node scripts/build-search.mjs",
    "crawl": "node scripts/crawl.mjs",
    "crawl:official": "node scripts/crawl.mjs --official",
    "crawl:news": "node scripts/crawl.mjs --type=news",
    "crawl:events": "node scripts/crawl.mjs --type=event",
    "crawl:guides": "node scripts/crawl.mjs --type=guide",
    "crawl:patch-notes": "node scripts/crawl.mjs --type=patch-note",
    "crawl:source": "node scripts/crawl.mjs",
    "crawl:backfill": "node scripts/backfill.mjs",
    "publish:content": "node scripts/content-publisher.mjs",
    "plan:translations": "node scripts/translation-plan.mjs",
    "enqueue:translations": "node scripts/translation-enqueue.mjs",
    "translation:worker": "node scripts/translation-worker.mjs",
    "translation:quality-requeue": "node scripts/translation-quality-requeue.mjs",
    "translation:evaluate-providers": "node scripts/provider-evaluation.mjs",
    "localization:sync-memory": "node scripts/localization-memory-sync.mjs",
    "localization:resolve-pilot": "node scripts/localization-resolve-pilot.mjs",
    "update:event-status": "node scripts/update-event-status.mjs",
    "generate:site-data": "node scripts/generate-site-data.mjs",
    "db:migrate": "node scripts/migrate-supabase.mjs",
    "check:tool-links": "node scripts/check-tool-links.mjs"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "linkedom": "^0.18.13",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-i18next": "^15.6.0",
    "react-router-dom": "^7.6.3",
    "remixicon": "4.5.0"
