{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mpstorys.com/schemas/content-release.schema.json",
  "title": "MPStorys immutable content release",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "manifest_uri",
    "manifest_hash",
    "generated_at",
    "source",
    "files"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "release_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "manifest_uri": {
      "type": "string",
      "minLength": 1,
      "format": "uri-reference"
    },
    "manifest_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "generated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "files": {
      "type": "integer",
      "minimum": 0
    }
  }
}
