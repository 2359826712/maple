{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mpstorys.com/schemas/article.schema.json",
  "title": "MapleStory content article",
  "type": "object",
  "allOf": [{ "$ref": "#/$defs/contentRecord" }],
  "unevaluatedProperties": false,
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "series": { "enum": ["maplestory", "classic", "m", "worlds", "n", "idle"] },
    "contentType": { "enum": ["news", "event", "guide", "patch-note", "maintenance", "cash-shop", "developer-note", "roadmap", "api-announcement", "creator-announcement"] },
    "storageMode": { "enum": ["metadata-only", "summary-and-metadata", "full-text-permitted"] },
    "contentStatus": { "enum": ["published", "updated", "expired", "removed", "redirected", "archived", "unknown"] },
    "translationStatus": { "enum": ["not-requested", "pending", "machine-translated", "human-reviewed", "not-applicable"] },
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "nullableDateOrDateTime": {
      "anyOf": [{ "type": "null" }, { "type": "string", "format": "date" }, { "type": "string", "format": "date-time" }]
    },
    "regions": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["global", "korea", "japan", "taiwan", "hong-kong", "macau", "china", "sea", "north-america", "europe", "oceania", "multi-region", "unknown"] }
    },
    "languages": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["en", "ko", "ja", "zh-hans", "zh-hant", "th", "vi", "id", "ms", "other", "unknown"] }
    },
    "image": {
      "type": "object", "additionalProperties": false, "required": ["url", "alt"],
      "properties": { "url": { "$ref": "#/$defs/httpsUrl" }, "alt": { "type": ["string", "null"] } }
    },
    "attachment": {
      "type": "object", "additionalProperties": false, "required": ["url", "title", "media_type"],
      "properties": {
        "url": { "$ref": "#/$defs/httpsUrl" },
        "title": { "type": ["string", "null"] },
        "media_type": { "type": ["string", "null"] }
      }
    },
    "contentRecord": {
      "type": "object",
      "required": [
        "id", "source_id", "canonical_url", "source_url", "external_id", "title",
        "original_title", "series", "regions", "languages", "content_type", "subcategory",
        "official", "author", "published_at", "updated_at", "discovered_at", "last_checked",
        "summary", "body_text", "body_markdown", "storage_mode", "tags", "images",
        "attachments", "related_content_ids", "related_urls", "content_hash", "status",
        "translation_status", "metadata", "notes"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "source_id": { "$ref": "#/$defs/slug" },
        "canonical_url": { "$ref": "#/$defs/httpsUrl" },
        "source_url": { "$ref": "#/$defs/httpsUrl" },
        "external_id": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" },
        "title": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "original_title": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "series": { "$ref": "#/$defs/series" },
        "regions": { "$ref": "#/$defs/regions" },
        "languages": { "$ref": "#/$defs/languages" },
        "content_type": { "$ref": "#/$defs/contentType" },
        "subcategory": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/slug" }] },
        "official": { "type": "boolean" },
        "author": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" },
        "published_at": { "$ref": "#/$defs/nullableDateOrDateTime" },
        "updated_at": { "$ref": "#/$defs/nullableDateOrDateTime" },
        "discovered_at": { "type": "string", "format": "date-time" },
        "last_checked": { "type": "string", "format": "date-time" },
        "summary": { "type": ["string", "null"], "minLength": 1, "maxLength": 1000, "pattern": "\\S" },
        "body_text": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" },
        "body_markdown": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" },
        "storage_mode": { "$ref": "#/$defs/storageMode" },
        "tags": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/slug" } },
        "images": { "type": "array", "items": { "$ref": "#/$defs/image" } },
        "attachments": { "type": "array", "items": { "$ref": "#/$defs/attachment" } },
        "related_content_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/slug" } },
        "related_urls": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/httpsUrl" } },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "status": { "$ref": "#/$defs/contentStatus" },
        "translation_status": { "$ref": "#/$defs/translationStatus" },
        "metadata": { "type": "object", "additionalProperties": true },
        "notes": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" }
      }
    }
  }
}
