{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mpstorys.com/schemas/source.schema.json",
  "title": "MapleStory monitored content source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "name", "series", "regions", "languages", "source_type",
    "content_types", "base_url", "discovery_urls", "feed_url", "api_url",
    "sitemap_urls", "adapter", "parser", "adapter_config", "official",
    "enabled", "crawl_frequency", "rate_limit", "requires_javascript",
    "requires_login", "storage_mode", "robots_policy", "last_checked",
    "last_success", "last_error", "notes"
  ],
  "properties": {
    "id": { "$ref": "#/$defs/slug" },
    "name": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "series": { "$ref": "#/$defs/series" },
    "regions": { "$ref": "#/$defs/regions" },
    "languages": { "$ref": "#/$defs/languages" },
    "source_type": {
      "enum": ["official-site", "wiki", "community-site", "blog", "forum", "rss", "atom", "sitemap", "json-api", "graphql-api", "github", "youtube", "other"]
    },
    "content_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/contentType" }
    },
    "base_url": { "$ref": "#/$defs/httpsUrl" },
    "discovery_urls": { "$ref": "#/$defs/urlArray" },
    "feed_url": { "$ref": "#/$defs/nullableHttpsUrl" },
    "api_url": { "$ref": "#/$defs/nullableHttpsUrl" },
    "sitemap_urls": { "$ref": "#/$defs/urlArray" },
    "adapter": { "enum": ["rss", "atom", "sitemap", "html", "json-api", "nexon-cms", "nexon-community", "graphql", "github", "youtube", "browser"] },
    "parser": { "$ref": "#/$defs/slug" },
    "adapter_config": { "type": "object", "additionalProperties": true },
    "official": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "crawl_frequency": { "type": "string", "pattern": "^[1-9][0-9]*[mhdw]$" },
    "rate_limit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "per_seconds"],
      "properties": {
        "requests": { "type": "integer", "minimum": 1, "maximum": 20 },
        "per_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 }
      }
    },
    "requires_javascript": { "type": "boolean" },
    "requires_login": { "type": "boolean" },
    "storage_mode": { "$ref": "#/$defs/storageMode" },
    "robots_policy": { "const": "respect" },
    "last_checked": { "$ref": "#/$defs/nullableDateTime" },
    "last_success": { "$ref": "#/$defs/nullableDateTime" },
    "last_error": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" },
    "notes": { "type": ["string", "null"], "minLength": 1, "pattern": "\\S" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "series": { "enum": ["maplestory", "classic", "m", "worlds", "n", "idle"] },
    "contentType": { "enum": ["news", "event", "guide", "patch-note", "maintenance", "cash-shop", "developer-note", "roadmap", "api-announcement", "creator-announcement"] },
    "storageMode": { "enum": ["metadata-only", "summary-and-metadata", "full-text-permitted"] },
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "nullableHttpsUrl": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/httpsUrl" }] },
    "urlArray": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/httpsUrl" } },
    "nullableDateTime": { "anyOf": [{ "type": "null" }, { "type": "string", "format": "date-time" }] },
    "regions": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["global", "korea", "japan", "taiwan", "hong-kong", "macau", "china", "sea", "north-america", "europe", "oceania", "multi-region", "unknown"] }
    },
    "languages": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["en", "ko", "ja", "zh-hans", "zh-hant", "th", "vi", "id", "ms", "other", "unknown"] }
    }
  }
}
