{
  "schema_version": 1,
  "policy_version": "2",
  "resolution_order": ["exact", "glossary", "memory", "template", "provider"],
  "provider_fallback": {
    "enabled": false,
    "reason": "Phase 2D requires deterministic localization resolution before any provider call."
  },
  "targets": ["zh", "zh-Hant", "ja", "ko"],
  "locale_aliases": {
    "zh-CN": "zh",
    "zh-TW": "zh-Hant"
  },
  "modules": {
    "news": {
      "fields": ["title", "summary"]
    },
    "upcoming": {
      "fields": ["title", "summary"]
    },
    "events": {
      "fields": ["title", "summary"]
    },
    "shop": {
      "fields": ["title"]
    },
    "guides": {
      "fields": ["title", "summary"]
    }
  }
}
