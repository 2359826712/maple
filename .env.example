# Local development uses /api through Vite. Hosted builds default to the
# Supabase maplehub-api Edge Function when this value is omitted.
VITE_MAPLE_SQL_API_BASE_URL=/api
VITE_MAPLE_SQL_TENANT_KEY=default

# Vite dev proxy target for the Go backend in D:/Desktop/maple_sql/backend.
MAPLE_SQL_API_ORIGIN=http://127.0.0.1:8080
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_ENDPOINT=/api/telemetry/events
VITE_INTERNAL_SESSION=false
